{% schema %}
{
  "name": "Today in History widget",
  "target": "section",
  "settings": [
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#D4AF37"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "Find Your Home"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link"
    },
    {
      "type": "select",
      "id": "theme",
      "label": "Theme Mode",
      "options": [
        { "value": "dark", "label": "Sleek Dark" },
        { "value": "light", "label": "Warm Light" }
      ],
      "default": "dark"
    }
  ]
}
{% endschema %}

<div id="tih-widget-container-shopify"></div>
<script 
  src="https://250proud.net/tih-widget-loader.js" 
  data-color="{{ block.settings.accent_color }}" 
  data-cta-text="{{ block.settings.cta_text }}" 
  data-cta-link="{{ block.settings.cta_link | default: 'https://250proud.net' }}" 
  data-theme="{{ block.settings.theme }}"
  defer>
</script>
