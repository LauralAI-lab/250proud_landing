{
  "version": 2,
  "cleanUrls": true,
  "headers": [
    {
      "source": "/tih-widget",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/tih-widget.html",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/tih-widget-loader.js",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/((?!tih-widget|tih-widget-loader).*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60,
        "includeFiles": [
          "250Proud_ColoringBook_B2B_Base_Final.pdf",
          "back_cover_template.html",
          "marketing_card_template.html"
        ]
      }
    },
    {
      "src": "api/subscribe.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/contact.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.xsl",
      "use": "@vercel/static"
    },
    {
      "src": "downloads/**/*.pdf",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.png",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.jpg",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.svg",
      "use": "@vercel/static"
    },
    {
      "src": "nc_assets/**/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "nc_assets/**/*.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/subscribe",
      "dest": "api/subscribe.js"
    },
    {
      "src": "/api/contact",
      "dest": "api/contact.js"
    },
    {
      "src": "/book/(?<slug>[^/]+)",
      "dest": "server.js"
    },
    {
      "src": "/qr/(?<slug>[^/]+)",
      "dest": "server.js"
    },
    {
      "src": "/resource",
      "status": 301,
      "headers": { "Location": "/resources" }
    },
    {
      "src": "/blueprint",
      "status": 302,
      "headers": { "Location": "/agent-blueprint-coming-soon" }
    },
    {
      "src": "/agent-blueprint",
      "status": 302,
      "headers": { "Location": "/agent-blueprint-coming-soon" }
    },
    {
      "src": "/research-citations",
      "status": 302,
      "headers": { "Location": "/citations" }
    },
    {
      "src": "/today-in-history",
      "dest": "/today-in-history.html"
    },
    {
      "src": "/tih-widget",
      "dest": "/tih-widget.html"
    },
    {
      "src": "/tih-widget-builder",
      "dest": "/tih-widget-builder.html"
    },
    {
      "src": "/rss.xml",
      "dest": "server.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
